# Frontend environment example for Covenant Diligence Systems.
# The Next.js app mostly uses server-side proxy routes, so API_INTERNAL_BASE_URL is the primary value.

NEXT_PUBLIC_APP_NAME=Covenant Diligence Systems
API_INTERNAL_BASE_URL=http://api:8000
API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEBUG_API=0
