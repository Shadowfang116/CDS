# Copy to .env.production and replace every placeholder before first deploy.
# This file uses the same canonical variable names as .env.example.

# === APP ===
APP_ENV=production
# Must be changed before deploy (minimum 32 random characters)
APP_SECRET_KEY=replace-with-32-plus-character-random-secret
APP_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
DEMO_MODE=false
CORS_ORIGINS=https://your-domain.com
PUBLIC_URL=https://your-domain.com
PUBLIC_HOSTNAME=your-domain.com
RULEPACK_PATH=/app/backend/rules/diligence_rules.yaml
INTEGRATIONS_ENCRYPTION_KEY=replace-with-32-plus-character-random-secret

# === DATABASE ===
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=bank_diligence
POSTGRES_USER=bank_diligence
POSTGRES_PASSWORD=replace-with-strong-postgres-password

# === REDIS ===
REDIS_URL=redis://redis:6379/0

# === OBJECT STORAGE (MINIO) ===
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ROOT_USER=replace-with-minio-user
MINIO_ROOT_PASSWORD=replace-with-strong-minio-password
MINIO_BUCKET=case-files
MINIO_REGION=us-east-1
MINIO_USE_SSL=false
MINIO_PUBLIC_ENDPOINT=your-domain.com
MINIO_PUBLIC_PORT=9000

# === FRONTEND / INTERNAL ROUTING ===
API_INTERNAL_BASE_URL=http://api:8000

# === OCR / EXTRACTION ===
OCR_ENGINE=surya
OCR_LANG=urd+eng
OCR_MAX_CONCURRENT_PAGES=2
OCR_MAX_WORKERS=1
CELERY_WORKER_CONCURRENCY=1
CELERY_PREFETCH_MULTIPLIER=1
OCR_SERVICE_CPUS=2.0
OCR_SERVICE_MEM_LIMIT=2g
OCR_SERVICE_URL=http://ocr_service:8001
HF_EXTRACTOR_URL=http://hf-extractor:8090
HF_EXTRACTOR_VERSION=rules-v1

# === EMAIL / WEBHOOKS ===
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_NAME=Bank Diligence Platform
SMTP_FROM_EMAIL=noreply@your-domain.com
WEBHOOK_DELIVERY_ENABLED=true
WEBHOOK_TIMEOUT_SECONDS=10
RETENTION_DAYS=365
DOC_CONVERT_TIMEOUT_SECONDS=90

# === HF MODEL OPTIONS (OPTIONAL) ===
INSTALL_ML_DEPS=0
INSTALL_VLM_DEPS=0
MODEL_NAME=microsoft/layoutxlm-base
EXTRACTOR_VERSION=layoutxlm-v1
DEVICE=cpu
HF_DEVICE=cpu
HF_LAYOUTXLM_MODEL_PATH=/models/layoutxlm
HF_ENABLE_QAARI=false
HF_QAARI_MODEL_PATH=
