# =========================
# CDS root environment example
# Copy to .env for local or pilot deployment.
# Do NOT commit real secrets.
# =========================

COMPOSE_PROJECT_NAME=cds
APP_ENV=development

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=bank_diligence
POSTGRES_USER=bank_diligence
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://bank_diligence:change-me@db:5432/bank_diligence

REDIS_URL=redis://redis:6379/0

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ROOT_USER=cds-minio
MINIO_ROOT_PASSWORD=change-me
MINIO_BUCKET=case-files
MINIO_REGION=us-east-1
MINIO_USE_SSL=false
MINIO_PUBLIC_ENDPOINT=localhost
MINIO_PUBLIC_PORT=9000
PUBLIC_URL=http://localhost

APP_SECRET_KEY=change-me-generate-a-long-random-secret
APP_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_INTERNAL_BASE_URL=http://api:8000

OCR_ENGINE=tesseract
OCR_SERVICE_URL=http://ocr_service:8001
HF_EXTRACTOR_URL=http://hf-extractor:8090
HF_EXTRACTOR_VERSION=rules-v1
OCR_ENABLE_ORIENTATION_DETECTION=true
OCR_LANG=urd+eng
OCR_MAX_CONCURRENT_PAGES=2
OCR_MAX_WORKERS=1
OCR_SERVICE_CPUS=2.0
OCR_SERVICE_MEM_LIMIT=2g
OCR_LOW_CHAR_COUNT_THRESHOLD=50
OCR_LOW_AVG_CONFIDENCE_THRESHOLD=40
OCR_HIGH_NOISE_RATIO_THRESHOLD=0.6
CELERY_WORKER_CONCURRENCY=1
CELERY_PREFETCH_MULTIPLIER=1

RETENTION_DAYS=3650
INTEGRATIONS_ENCRYPTION_KEY=
EMAIL_ENABLED=false
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_FROM_NAME=Covenant Diligence Systems
SMTP_FROM_EMAIL=noreply@cds.local
WEBHOOK_DELIVERY_ENABLED=true
WEBHOOK_TIMEOUT_SECONDS=10

DEMO_MODE=false
RULEPACK_PATH=/app/docs/05_rulepack_v1.yaml
DOC_CONVERT_TIMEOUT_SECONDS=90
