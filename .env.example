# Copy to .env and set real secrets for production.
# For production: APP_ENV=production and use strong secrets (see config.py assert_production_safe).
# Local Docker defaults below are safe for a fresh clone.

APP_ENV=development

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=bank_diligence
POSTGRES_PASSWORD=change_me
POSTGRES_DB=bank_diligence

APP_SECRET_KEY=change_me_to_random_secret_key
APP_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me
MINIO_REGION=us-east-1
MINIO_BUCKET=case-files
MINIO_USE_SSL=false
MINIO_EXTERNAL_ENDPOINT=localhost
MINIO_EXTERNAL_PORT=9000
PUBLIC_URL=http://localhost

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
REDIS_URL=redis://redis:6379/0

INTEGRATIONS_ENCRYPTION_KEY=

EMAIL_ENABLED=false
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_FROM_NAME=Bank Diligence Platform
SMTP_FROM_EMAIL=noreply@bankdiligence.local
WEBHOOK_DELIVERY_ENABLED=true
WEBHOOK_TIMEOUT_SECONDS=10

HF_EXTRACTOR_URL=http://hf-extractor:8090
HF_EXTRACTOR_VERSION=rules-v1
OCR_SERVICE_URL=http://ocr_service:8001
API_INTERNAL_BASE_URL=http://api:8000

# Enable orientation detection before OCR runs.
OCR_ENABLE_ORIENTATION_DETECTION=true
# Default OCR languages for mixed Urdu and English pages.
OCR_LANG=urd+eng
# Conservative OCR page concurrency on pilot CPU hosts.
OCR_MAX_CONCURRENT_PAGES=2
# Limit OCR service worker threads for CPU-heavy OCR.
OCR_MAX_WORKERS=1
# Keep Celery worker concurrency conservative while OCR is CPU-bound.
CELERY_WORKER_CONCURRENCY=1
# Avoid prefetching multiple CPU-heavy OCR tasks.
CELERY_PREFETCH_MULTIPLIER=1
# Compose-level CPU and memory guardrails for OCR service.
OCR_SERVICE_CPUS=2.0
OCR_SERVICE_MEM_LIMIT=2g
# Flag OCR output when extracted text is too short.
OCR_LOW_CHAR_COUNT_THRESHOLD=50
# Flag OCR output when average confidence is too low.
OCR_LOW_AVG_CONFIDENCE_THRESHOLD=40
# Escalate OCR output when symbol noise is unusually high.
OCR_HIGH_NOISE_RATIO_THRESHOLD=0.6
