# Production env template. Copy to .env and replace ALL REPLACE_ME_* with strong secrets.
# Do not use placeholders in production; APP_ENV=production will fail startup.
# See docs/ops/ENVIRONMENT_MATRIX.md for details.

APP_ENV=production

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=bank_diligence
POSTGRES_PASSWORD=REPLACE_ME_WITH_STRONG_SECRET_MIN_12
POSTGRES_DB=bank_diligence

APP_SECRET_KEY=REPLACE_ME_WITH_STRONG_SECRET_MIN_32
APP_ALGORITHM=HS256
APP_ACCESS_TOKEN_EXPIRE_HOURS=24

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=REPLACE_ME_WITH_STRONG_SECRET_MIN_12
MINIO_REGION=us-east-1
MINIO_BUCKET=case-files
MINIO_USE_SSL=false
MINIO_EXTERNAL_ENDPOINT=YOUR_PUBLIC_HOSTNAME
MINIO_EXTERNAL_PORT=9000

CORS_ORIGINS=https://YOUR_PUBLIC_HOSTNAME

RETENTION_DAYS=365
DOC_CONVERT_TIMEOUT_SECONDS=90

INTEGRATIONS_ENCRYPTION_KEY=REPLACE_ME_WITH_STRONG_SECRET_MIN_32

EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_FROM_NAME=Bank Diligence Platform
SMTP_FROM_EMAIL=noreply@bankdiligence.local

WEBHOOK_DELIVERY_ENABLED=true
WEBHOOK_TIMEOUT_SECONDS=10

HF_EXTRACTOR_URL=http://hf-extractor:8090
HF_EXTRACTOR_VERSION=rules-v1
HF_EXTRACTOR_ENABLE_LAYOUTXLM=false
HF_LAYOUTXLM_MODEL_PATH=

API_INTERNAL_BASE_URL=http://api:8000
